# ApplyOnce AI – Extension Environment Variables Example
# Duplicate this file as .env and fill in your actual API keys.
# SECURITY NOTE: For production, move API calls to a backend proxy.

# Gemini API (Primary) - Get key at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Groq API (Secondary) - Get key at: https://console.groq.com/
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Cerebras API (Tertiary) - Get key at: https://cloud.cerebras.ai/
VITE_CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY_HERE

# OpenRouter API (Fallback) - Get key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
